    "agents/investigador.md",
    "agents/dev-senior.md",
    "agents/revisor.md",
    "agents/auditor-seguranca.md",
    "agents/auditor-qualidade.md",
    "agents/auditor-produto.md",
    "agents/fiscal-br.md",
    "agents/tech-writer.md"
