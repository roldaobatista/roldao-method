{
  "$schema": "https://json.schemastore.org/claude-code-plugin.json",
  "name": "roldao-method",
  "version": "0.13.0",
  "description": "Framework de desenvolvimento ágil assistido por IA em português brasileiro. 12 agentes, 22 hooks bloqueadores (gates mecânicos pra readiness/sequência de agentes/dependências/escopo de quick-dev/REGRA #0), 21 workflows, 8 skills BR core + 14 em addons, 8 checklists, 7 KBs, 6 addons BR. Para Claude Code, Cursor, Windsurf, Cline, Roo, Aider, Gemini CLI, Codex CLI.",
  "author": "Roldão Batista",
  "homepage": "https://github.com/roldaobatista/roldao-method",
  "license": "MIT",
  "keywords": [
    "pt-br",
    "brazil",
    "lgpd",
    "nfe",
    "pix",
    "fiscal",
    "agile",
    "spec-driven",
    "agents",
    "hooks"
  ],
