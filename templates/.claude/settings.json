{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "outputStyle": "pt-br-conciso",
  "env": {
    "LANG": "pt_BR.UTF-8",
    "LC_ALL": "pt_BR.UTF-8"
  },
  "statusLine": {
    "type": "command",
    "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/statusline.js\"",
    "padding": 0
