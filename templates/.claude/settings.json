      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/id_rsa*)",
      "Read(./**/*.pfx)",
      "Read(./**/*.p12)",
      "Read(./**/certificado*.xml)",
      "Read(./**/cert-a1/**)",
      "Read(./**/cert-a3/**)",
      "Read(./**/certificados/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)",
      "Write(./**/*.pfx)",
      "Write(./**/*.p12)",
      "Write(./**/cert-a1/**)",
      "Write(./**/cert-a3/**)"
