{
  "name": "roldao-method",
  "version": "0.20.0",
  "description": "Framework agentic em PT-BR. 15 agentes, 26 hooks bloqueadores + 2 soft warnings + 5 lifecycle, 26 workflows, 29 skills BR (13 core + 16 em addons; CNPJ alfanumérico 2026, chave de acesso NF-e, Reforma Tributária 2026-2033, Pix, LGPD, fiscal, eSocial), 6 addons especializados. Spec-driven com adapters pra Claude Code, Cursor, Windsurf, Cline, Roo, Aider, Continue, Gemini CLI, Codex CLI.",
  "keywords": [
    "ai",
    "claude-code",
    "cursor",
    "windsurf",
    "cli",
    "agile",
    "framework",
    "scaffolding",
    "developer-tools",
    "brazil",
    "portugues",
    "pt-br",
    "lgpd",
    "nfe",
    "fiscal",
    "pix",
    "cnpj-alfanumerico",
    "reforma-tributaria",
    "agents",
    "hooks",
    "spec-driven",
    "open-finance",
    "esocial",
    "anpd",
    "dpo",
    "ripd",
    "addons",
    "cline",
    "roo",
    "aider"
  ],
  "scripts": {
    "validar": "node tools/validar-templates.js",
    "validar:ids": "node tools/validar-ids-rastreaveis.js",
    "validar:cobertura-hooks": "node tools/validar-cobertura-hooks.js",
    "test:hooks": "bash templates/.claude/hooks/_test-runner.sh",
    "test:install": "node test/install.test.js",
    "test:install-lib": "node test/install-lib.test.js",
    "test:lib-equivalence": "node test/lib-equivalence.test.js",
    "test:hooks-equivalence": "node test/hooks-equivalence.test.js",
    "test:hooks-state-equivalence": "node test/hooks-state-equivalence.test.js",
    "test:hooks-node-only": "node test/hooks-node-only.test.js",
    "test:skills": "node test/skills.test.js",
    "test:addons": "node test/addons.test.js",
    "test:adapters": "node test/adapters.test.js",
    "test:adapter-drift": "node tools/sincronizar-adapters.js --check --quiet",
    "test:claude-md-sync": "node tools/sincronizar-claude-md.js",
    "test:tools": "node test/validar-tools.test.js",
    "test": "npm run validar && npm run validar:ids && npm run validar:cobertura-hooks && npm run test:tools && npm run test:claude-md-sync && npm run test:hooks && npm run test:install-lib && npm run test:install && npm run test:lib-equivalence && npm run test:hooks-equivalence && npm run test:hooks-state-equivalence && npm run test:hooks-node-only && npm run test:skills && npm run test:addons && npm run test:adapters",
    "prepublishOnly": "npm test && npm run test:adapter-drift"
  },
  "homepage": "https://github.com/roldaobatista/roldao-method",
  "license": "MIT",
  "author": {
    "name": "Roldão Batista",
    "url": "https://github.com/roldaobatista"
  },
  "main": "bin/install.js",
  "bin": {
    "roldao-method": "./bin/install.js",
    "roldao": "./bin/install.js"
  },
  "files": [
    "bin",
    "templates",
    "addons",
    "docs",
    "tools",
    "test",
    "README.md",
    "CHANGELOG.md",
    "ROADMAP.md",
    "SECURITY.md",
    "CONTRIBUTORS.md",
    "LICENSE",
    "!docs/PUBLICAR-NPM.md"
  ],
  "bugs": {
    "url": "https://github.com/roldaobatista/roldao-method/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roldaobatista/roldao-method.git"
  }
